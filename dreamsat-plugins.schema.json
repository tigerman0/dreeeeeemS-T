{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://your-domain.example/schemas/dreamsat-plugins.schema.json",
  "title": "DreamSat Plugins API",
  "type": "object",
  "required": [
    "Plugins"
  ],
  "additionalProperties": true,
  "properties": {
    "Plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "Title",
          "links"
        ],
        "additionalProperties": true,
        "properties": {
          "Title": {
            "type": "string",
            "minLength": 1
          },
          "links": {
            "type": "array",
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 3,
              "prefixItems": [
                {
                  "type": "string",
                  "description": "Display name shown by the plugin"
                },
                {
                  "type": "string",
                  "format": "uri",
                  "pattern": "^https?://",
                  "description": "Direct .ipk, .deb or .sh URL"
                },
                {
                  "type": [
                    "string",
                    "number"
                  ],
                  "description": "Optional version; numeric-looking value is safest"
                }
              ],
              "items": false
            }
          }
        }
      }
    }
  }
}
